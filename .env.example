NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Frontend. En Vercel, si frontend y API viven en el mismo proyecto, puede omitirse.
# Para desarrollo local usar http://localhost:3000.
VITE_API_URL=http://localhost:3000

# JWT
PASS_JWT=change_me

# Verificacion de email de registro mediante SMTP/Nodemailer.
# En desarrollo, si estas variables no estan completas, el link se imprime en consola.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=change_me
SMTP_FROM=MiObra <mailer@example.com>

# Las invitaciones de empleados conservan el proveedor Resend.
RESEND_API_KEY=
EMAIL_FROM=MiObra <no-reply@example.com>

# Mongo selector: usar "atlas" para MongoDB Atlas o "local" para Mongo local.
MONGO_BD_IN_USE=atlas

# Opcion recomendada para Atlas: pegar el connection string completo desde MongoDB Atlas.
MONGO_ATLAS_URI=mongodb+srv://<user>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority&appName=<app-name>

# Opcion alternativa para Atlas: armar el URI por partes.
# Si MONGO_ATLAS_URI existe, tiene prioridad sobre estas variables.
MONGO_ATLAS=<cluster-host>
MONGO_ATLAS_USER=<user>
MONGO_ATLAS_PASS=<password>
MONGO_ATLAS_DB=miobra_db
MONGO_ATLAS_APP_NAME=Miobra

# Mongo local. Se usa cuando MONGO_BD_IN_USE no es "atlas".
MONGO_URL=localhost
MONGO_PORT=27017
MONGO_DB=miobra_db

